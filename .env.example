# ===========================================================================
# ACE — Autonomous Coding Engine  ·  Environment configuration
# Copy this file to `.env` and fill in the one required secret.
# ===========================================================================

# --- LLM reasoning backend -------------------------------------------------
# LLM_MODE = anthropic | local
#   anthropic : real Claude API calls (recommended; demo default). Needs ANTHROPIC_API_KEY.
#   local     : point at a local OpenAI-compatible endpoint (e.g. Ollama) for air-gapped runs.
# If no LLM is reachable, the pipeline does NOT fabricate codes — it routes every
# chart to the manual queue with reason LLM_UNAVAILABLE. (No fake logic, ever.)
LLM_MODE=anthropic

# Required when LLM_MODE=anthropic
ANTHROPIC_API_KEY=

# Model tiering (per DESIGN.md §3 / §16): Sonnet for most, Opus for hard encounters.
ACE_MODEL_DEFAULT=claude-sonnet-4-5
ACE_MODEL_HARD=claude-opus-4-1

# Used when LLM_MODE=local (OpenAI-compatible). Example for Ollama:
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b

# --- Database (defaults match docker-compose) ------------------------------
POSTGRES_USER=ace
POSTGRES_PASSWORD=ace_dev_pw
POSTGRES_DB=ace
DATABASE_URL=postgresql+psycopg://ace:ace_dev_pw@db:5432/ace

# --- App -------------------------------------------------------------------
ACE_ENV=demo
# Number of self-consistency samples on hard encounters (Stage 3b).
ACE_SELF_CONSISTENCY_SAMPLES=3
# Auto-seed reference data + synthetic charts on first API boot.
ACE_AUTO_SEED=true
